# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Ignore environment variables file
.env

# Virtual environments
.venv

# Alembic - DO track versions, but ignore their caches
alembic/versions/__pycache__/

# Static libraries (Keep if you want bootstrap tracked, or ignore if using CDN)
# bootstrap* # Databases
app.db

# Ignore Windows Alternate Data Stream metadata files
*Zone.Identifier

# Ignore Bootstrap assets
app/static/css/bootstrap*
app/static/js/bootstrap*
